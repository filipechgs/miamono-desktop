{
  "name": "miamono-desktop",
  "version": "1.0.0",
  "description": "Aplicativo desktop open source para registro, consulta e exportação de recebimentos, pensado para profissionais liberais que precisam manter controle financeiro organizado e histórico confiável.",
  "main": "dist/main/main.js",
  "directories": {
    "doc": "doc"
  },
  "scripts": {
    "build": "esbuild src/main/main.ts src/preload/preload.ts --bundle --platform=node --format=esm --outdir=dist --external:electron --external:sqlite",
    "dev": "npm run build && electron .",
    "start": "npm run build && electron .",
    "migrate": "node --experimental-strip-types src/scripts/migrate.ts",
    "test": "node --experimental-strip-types --test src/shared/utils/name-normalizer.test.ts src/infrastructure/repositories/sqlite/sqlite-receipt-repository.test.ts",
    "check": "node --experimental-strip-types --check src/main/main.ts",
    "check:migrate": "node --experimental-strip-types --check src/scripts/migrate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "type": "module",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "esbuild": "^0.28.0"
  }
}
